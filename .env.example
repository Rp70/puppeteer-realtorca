# Strapi API Configuration
# Copy this file to .env and fill in your values

# Strapi API base URL (without /api suffix)
API_BASE_URL=http://localhost:1337

# Strapi full-access API token
# Create one at: http://localhost:1337/admin > Settings > API Tokens > Create new (Full access)
API_TOKEN=your-strapi-full-access-token-here

# Optional: Google Maps API key for geocoding missing coordinates
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Skip amenities creation (speeds up import significantly)
# SKIP_AMENITIES=false

# Optional: Default city image URL for newly created cities
# DEFAULT_CITY_IMAGE_URL=https://images.unsplash.com/photo-1480714378408-67cf0d13bc1b?w=800
